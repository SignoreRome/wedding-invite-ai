generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Rsvp {
  id            Int      @id @default(autoincrement())
  guestName     String   @map("guest_name")
  isAttending   Boolean  @map("is_attending")
  hasPlusOne    Boolean  @default(false) @map("has_plus_one")
  plusOneName   String?  @map("plus_one_name")
  needsTransfer Boolean  @default(false) @map("needs_transfer")
  guestComment  String?  @map("guest_comment")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("rsvp")
}
