generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Rsvp {
  id            Int      @id @default(autoincrement())
  guestName     String   @map("guest_name")
  isAttending   Boolean  @map("is_attending")
  hasPlusOne    Boolean  @default(false) @map("has_plus_one")
  plusOneName   String?  @map("plus_one_name")
  needsTransfer Boolean  @default(false) @map("needs_transfer")
  guestComment  String?  @map("guest_comment")
  rsvpInfo      String?  @map("rsvp_info")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("rsvp")
}

model GameAttempt {
  id             Int      @id @default(autoincrement())
  mode           String
  playerName     String?  @map("player_name")
  score          Int
  coinsCollected Int      @map("coins_collected")
  distance       Int
  isSuccess      Boolean  @default(false) @map("is_success")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("game_attempts")
}

model GameSettings {
  id                     Int      @id
  storyRequiredDistance  Int      @default(2500) @map("story_required_distance")
  endlessSpeedMultiplier Float    @default(1) @map("endless_speed_multiplier")
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("game_settings")
}
