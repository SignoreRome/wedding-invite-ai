generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model RsvpResponse {
  id                  String   @id @default(cuid())
  guestName           String
  attendance          String
  dietaryRestrictions String?
  guestMessage        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
