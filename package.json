{
  "name": "wedding-invite-ai",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "postinstall": "prisma generate",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:prepare": "node scripts/ensure-sqlite-db.mjs",
    "db:migrate:create": "npm run db:prepare && prisma migrate dev --create-only",
    "db:migrate": "npm run db:prepare && prisma migrate dev",
    "db:deploy": "npm run db:prepare && prisma migrate deploy",
    "db:studio": "npm run db:prepare && prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "next": "16.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.2.3",
    "postcss": "^8.4.49",
    "prettier": "^3.3.1",
    "prisma": "^7.7.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
