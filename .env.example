# Local development SQLite database.
DATABASE_URL="file:./data/dev.db"

# VPS production example. Keep this path outside .next and release build folders.
# DATABASE_URL="file:/var/www/wedding-invite/shared/data/production.db"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Replace in production with a long private value.
ADMIN_RSVP_PASSWORD="change-this-admin-password"

# Used by the standalone Next.js server on VPS.
PORT=3000
